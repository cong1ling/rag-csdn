[Unit]
Description=RAG Bilibili Server
After=network.target mysql.service
Wants=mysql.service

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/rag-bilibili-server
ExecStart=/usr/bin/java -Xms512m -Xmx2g -jar /home/ubuntu/rag-bilibili-server/rag-bilibili-server-1.0.0.jar
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

# 环境变量配置
# 数据库配置
Environment="DB_USERNAME=raguser"
Environment="DB_PASSWORD=your_strong_password_here"
Environment="SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/rag_bilibili?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai"

# AI 模型配置
Environment="OPENAI_API_KEY=sk-your-openai-key-here"
Environment="OPENAI_BASE_URL=https://api.deepseek.com"

# 阿里云 DashScope（文本向量化）
Environment="DASHSCOPE_API_KEY=sk-your-dashscope-key-here"

# 阿里云 DashVector（向量数据库）
Environment="DASHVECTOR_API_KEY=your-dashvector-key-here"
Environment="DASHVECTOR_ENDPOINT=your-dashvector-endpoint-here"

# CORS 配置（允许的前端域名，多个用逗号分隔）
Environment="CORS_ALLOWED_ORIGINS=https://your-app.pages.dev,https://app.yourdomain.com"

# 应用配置
Environment="SERVER_PORT=8080"
Environment="SPRING_PROFILES_ACTIVE=prod"

[Install]
WantedBy=multi-user.target
