spring:
  application:
    name: rag-bilibili-server

  autoconfigure:
    exclude:
      - org.springframework.ai.model.chat.client.autoconfigure.ChatClientAutoConfiguration
      - com.alibaba.cloud.ai.autoconfigure.dashscope.DashScopeEmbeddingAutoConfiguration

  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/rag_bilibili?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
    username: root
    password: your_password_here

  sql:
    init:
      mode: never

  flyway:
    enabled: true
    locations: classpath:db/migration

  ai:
    model:
      chat: openai
      embedding: dashscope

    openai:
      api-key: ${OPENAI_API_KEY}
      base-url: ${OPENAI_BASE_URL:https://api.openai.com}
      chat:
        options:
          model: gpt-3.5-turbo
          temperature: 0.7

    dashscope:
      api-key: ${DASHSCOPE_API_KEY}
      embedding:
        options:
          model: text-embedding-v4
          dimensions: 1024

    alibaba:
      dashvector:
        api-key: ${DASHVECTOR_API_KEY}
        endpoint: ${DASHVECTOR_ENDPOINT}
        collection: rag_bilibili

mybatis:
  mapper-locations: classpath:mapper/*.xml
  type-aliases-package: com.example.ragbilibili.entity
  configuration:
    map-underscore-to-camel-case: true
    # 生产环境应注释掉以下行，避免 SQL 日志泄露数据
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl

server:
  port: 8080
  # 反向代理头信任策略：
  # - FRAMEWORK: 在 Nginx/云负载均衡后部署时使用，Spring 自动从 X-Forwarded-* 提取真实 IP
  # - NONE: 直接暴露公网、无反向代理时使用，忽略所有代理头防止 IP 伪造
  forward-headers-strategy: FRAMEWORK

# JWT 配置
jwt:
  # 签名密钥，必须 >= 32 字节（256 bit），建议使用随机生成的长字符串
  # 可通过 openssl rand -base64 48 生成
  secret: ${JWT_SECRET:CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_BYTES}
  # Token 过期时间（毫秒），86400000 = 24 小时
  expiration: ${JWT_EXPIRATION:86400000}

logging:
  level:
    com.example.ragbilibili: INFO
    org.springframework.ai: DEBUG
  pattern:
    console: "%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n"
