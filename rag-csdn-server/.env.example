# Database
DB_USERNAME=root
DB_PASSWORD=123456

# JWT
JWT_SECRET=replace_with_a_long_random_secret

# Optional: dedicated secret for encrypting third-party session cookies
CREDENTIALS_SECRET=replace_with_another_long_random_secret

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# OpenAI Compatible Chat Service
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com

# Alibaba Cloud DashScope
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Alibaba Cloud DashVector
DASHVECTOR_API_KEY=your_dashvector_api_key_here
DASHVECTOR_ENDPOINT=your_dashvector_endpoint_here

# Optional
REGISTER_ENABLED=true
