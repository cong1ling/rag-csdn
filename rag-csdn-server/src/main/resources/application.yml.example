spring:
  application:
    name: rag-csdn-server

  autoconfigure:
    exclude:
      - org.springframework.ai.model.chat.client.autoconfigure.ChatClientAutoConfiguration
      - com.alibaba.cloud.ai.autoconfigure.dashscope.DashScopeEmbeddingAutoConfiguration

  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/rag_csdn?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
    username: root
    password: your_password_here

  sql:
    init:
      mode: never

  flyway:
    enabled: true
    locations: classpath:db/migration

  ai:
    model:
      chat: openai
      embedding: dashscope

    openai:
      api-key: ${OPENAI_API_KEY}
      base-url: ${OPENAI_BASE_URL:https://api.openai.com}
      chat:
        options:
          model: gpt-3.5-turbo
          temperature: 0.7

    dashscope:
      api-key: ${DASHSCOPE_API_KEY}
      embedding:
        options:
          model: text-embedding-v4
          dimensions: 1024

    alibaba:
      dashvector:
        api-key: ${DASHVECTOR_API_KEY}
        endpoint: ${DASHVECTOR_ENDPOINT}
        collection: csdn
        default-top-k: 5
        similarity-threshold: 0.35

mybatis:
  mapper-locations: classpath:mapper/*.xml
  type-aliases-package: com.example.ragcsdn.entity
  configuration:
    map-underscore-to-camel-case: true
    # 生产环境应注释掉以下行，避免 SQL 日志泄露数据
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl

server:
  port: 8080
  # 反向代理头信任策略：
  # - FRAMEWORK: 在 Nginx/云负载均衡后部署时使用，Spring 自动从 X-Forwarded-* 提取真实 IP
  # - NONE: 直接暴露公网、无反向代理时使用，忽略所有代理头防止 IP 伪造
  forward-headers-strategy: FRAMEWORK

# JWT 配置
jwt:
  # 签名密钥，必须 >= 32 字节（256 bit），建议使用随机生成的长字符串
  # 可通过 openssl rand -base64 48 生成
  secret: ${JWT_SECRET}
  # Token 过期时间（毫秒），86400000 = 24 小时
  expiration: ${JWT_EXPIRATION:86400000}

logging:
  level:
    com.example.ragcsdn: INFO
    org.springframework.ai: DEBUG
  pattern:
    console: "%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n"

rag:
  chat:
    max-history: 10
    query-rewrite-enabled: true
    query-understanding-enabled: true
    hyde-enabled: true
    decomposition-enabled: true
    max-decomposed-queries: 4
    hybrid-search-enabled: true
    keyword-top-k: 8
    rerank-enabled: true
    rerank-candidate-top-k: 20
    model-rerank-enabled: false
    model-rerank-top-k: 8
    dynamic-top-k-enabled: true
    simple-top-k: 3
    normal-top-k: 5
    complex-top-k: 8
    summary-enabled: true
    summary-trigger-messages: 10
    summary-recent-messages: 6
    summary-max-length: 150
    confidence-aware-enabled: true
  ingest:
    chunking:
      chunk-size: 512
      min-chunk-size-chars: 256
      min-chunk-length-to-embed: 5
      max-num-chunks: 10000
      keep-separator: true
      overlap-chars: 128
